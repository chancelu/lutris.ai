# Lutris.ai AI Configuration
# Copy this file to .env.local and fill in your API key

# AI Provider: openrouter | anthropic | openai | google | zai | minimax | openai-compatible | anthropic-compatible
VITE_AI_PROVIDER=openai-compatible

# API Key
VITE_AI_API_KEY=

# For openai-compatible / anthropic-compatible providers:
VITE_AI_BASE_URL=
VITE_AI_MODEL=
VITE_AI_API_TYPE=completions

# Figma OAuth (optional — enables "Import from Figma" cloud import)
# Client-side (Vite)
VITE_FIGMA_CLIENT_ID=
VITE_FIGMA_REDIRECT_URI=http://localhost:5173/figma-callback
# Server-side (Vercel dashboard / .env for api/figma-oauth.js)
# FIGMA_CLIENT_ID=
# FIGMA_CLIENT_SECRET=
# FIGMA_REDIRECT_URI=http://localhost:5173/figma-callback
