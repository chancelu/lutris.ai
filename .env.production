# Production environment — Lutris.ai
# Real values are set in Vercel Environment Variables.
# Do NOT put actual keys here — this file is committed to git.

# AI Provider — Text (Google Gemini)
VITE_AI_PROVIDER=google
VITE_AI_MODEL=gemini-3.1-pro-preview

# AI Provider — Image (Google Gemini)
VITE_GEMINI_MODEL=gemini-3-pro-image-preview
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
